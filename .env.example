SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Admin JWT'lerini her istekte Supabase Auth'a gitmeden YEREL doğrulamak için.
# Supabase paneli → Settings → API → "JWT Secret" (legacy/HS256) değeri.
# Tanımlanmazsa sistem güvenli şekilde getUser() ağ doğrulamasına geri döner (eski davranış).
SUPABASE_JWT_SECRET=

TALPA_MEMBER_API_URL=https://talpa-uye.vercel.app/api/members/verify
TALPA_API_KEY=

# CORS: izin verilen origin'ler (virgülle ayrılmış). Boş bırakılırsa tüm
# origin'lere açık olur (yalnızca yerel geliştirme için önerilir).
# Örn: CORS_ORIGINS=https://talpa-giyim.vercel.app,https://kampanya.talpa.org
CORS_ORIGINS=

# Frontend (Vite) — istemci tarafında okunur
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Not: Admin yetkisi artık ADMIN_PASSWORD ile değil, Supabase Auth + `admins`
# allowlist tablosu ile yönetilir (bkz. wiki/reference/admin.md).
